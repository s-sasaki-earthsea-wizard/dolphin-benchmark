# Copy this file to .env and fill in real values.

# --- NASA Earthdata credentials, used by asf_search / opera_utils.download.
# Sign up free at: https://urs.earthdata.nasa.gov/users/new
ASF_USERNAME=your_username
ASF_PASSWORD=your_password

# --- Host paths for bind mounts. Use absolute paths. Both are REQUIRED.
#
# DATA_DIR:       where your raw Sentinel-1 SAFE files live (mounted /data, ro).
#                 If you don't have SAFE files yet, point this anywhere readable
#                 (e.g. /tmp) — the mount is needed by docker-compose but
#                 unused for the tutorial-CSLC workflow.
# OPERA_CSLC_DIR: where downloaded OPERA CSLC tutorial files go (mounted /cslc, rw).
#                 Pick a path with several tens of GB free.
DATA_DIR=/absolute/path/to/sentinel-1-data
OPERA_CSLC_DIR=/absolute/path/to/opera-cslc-tutorial
